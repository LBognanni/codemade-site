<section id="{{ section.section_id }}" class="software">
  {% if section.title | isNotEmpty %}
  <div class="section-label">{{ section.title }}</div>
  {% endif %}
  {% if section.features | isNotEmpty %}
  <div class="sw-grid">
    {% for feature in section.features %}
    {% if feature.actions | isNotEmpty %}
    <a href="{{ feature.actions[0].url | relativeUrl }}" class="sw-card">
    {% else %}
    <div class="sw-card">
    {% endif %}
      {% if feature.image | isNotEmpty %}
      <div class="sw-img">
        <img src="{{ feature.image | relativeUrl }}" alt="{{ feature.title }}" />
      </div>
      {% endif %}
      <div class="sw-body">
        <div class="sw-title-row">
          {% if feature.icon | isNotEmpty %}<span class="sw-icon">{{ feature.icon }}</span>{% endif %}
          <h3>{{ feature.title }}</h3>
        </div>
        <p>{{ feature.content }}</p>
        <div class="sw-footer">
          <div class="sw-tags">
            {% for tag in feature.tags %}
            <span class="sw-tag tag-{{ tag }}">{{ tag }}</span>
            {% endfor %}
          </div>
          <span class="sw-arrow">→</span>
        </div>
      </div>
    {% if feature.actions | isNotEmpty %}
    </a>
    {% else %}
    </div>
    {% endif %}
    {% endfor %}
  </div>
  {% endif %}
</section>
