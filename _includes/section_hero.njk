<section class="hero" id="{{ section.section_id }}">
  {% if section.tag | isNotEmpty %}
  <div class="hero-tag">{{ section.tag }}</div>
  {% else %}
  <div class="hero-tag">~ free software &amp; maker notes</div>
  {% endif %}
  {% if section.title | isNotEmpty %}
  <h1>{{ section.title | safe }}</h1>
  {% endif %}
  {% if (section.content or site.tagline) | isNotEmpty %}
    {{ section.content or (site.tagline | markdownify | safe) }}
  {% endif %}
  {% if section.actions | isNotEmpty %}
  <div class="hero-ctas">
    {% for action in section.actions %}
    <a href="{{ action.url | relativeUrl }}" class="btn {% if loop.first %}btn-warm{% else %}btn-dim{% endif %}">{{ action.label }}</a>
    {% endfor %}
  </div>
  {% endif %}
</section>