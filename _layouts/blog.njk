---
layout: body
---

<section class="blog blog-listing">
  <div class="section-label">{{ title }}</div>
  <div class="blog-grid">
    {% for post in collections.posts | reverse %}
    <a href="{{ post.url | relativeUrl }}" class="blog-card">
      {% if post.data.thumb_image | isNotEmpty %}
      <div class="blog-card-img">
        <img src="{{ post.data.thumb_image | relativeUrl }}" alt="{{ post.data.title }}" loading="lazy" />
      </div>
      {% endif %}
      <div class="blog-card-body">
        <div class="blog-card-date">{{ post.date | formatDate('short') }}</div>
        <h3>{{ post.data.title }}</h3>
        <p>{{ post.data.excerpt }}</p>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
